# Database (PostgreSQL with the vector extension)
DATABASE_URL="postgresql://user:password@localhost:5432/adas?schema=public"

# Redis (BullMQ)
REDIS_HOST="127.0.0.1"
REDIS_PORT="6379"

# API
PORT="3001"
WEB_ORIGIN="http://localhost:3000"

# Auth (Clerk) — add your keys in production
CLERK_SECRET_KEY=""
CLERK_PUBLISHABLE_KEY=""

# AI providers
# ANTHROPIC_API_KEY: when set, the agent pipeline uses claude-opus-4-7 with adaptive
# thinking for real explanations + supplement drafting. Leave empty in dev/CI to fall
# back to the deterministic stub (no API calls, predictable output for tests).
# Get one at https://console.anthropic.com
ANTHROPIC_API_KEY=""

# Force the stub even with a key present (useful in CI):
# LLM_PROVIDER="stub"

OPENAI_API_KEY=""

# Object storage (S3-compatible)
S3_BUCKET=""
S3_REGION=""
S3_ACCESS_KEY_ID=""
S3_SECRET_ACCESS_KEY=""
